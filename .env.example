# =============================================================================
# AI-dev-template — Environment Variables Example
# Скопируйте в .env и заполните нужные переменные.
# Никогда не коммитьте .env в репозиторий.
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=owner/repo-name
GITHUB_PROJECT_URL=https://github.com/orgs/<org>/projects/<number>

# -----------------------------------------------------------------------------
# Vector DB (опционально — заполняется только при согласии с агентом)
# -----------------------------------------------------------------------------

# Qdrant (используется в docker-compose.vector-db.yml)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Embedding provider (выберите один вариант)

# --- OpenAI Embeddings ---
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai

# --- Другой внешний провайдер (пример: Cohere) ---
# COHERE_API_KEY=
# EMBEDDING_MODEL=embed-multilingual-v3.0
# EMBEDDING_PROVIDER=cohere

# --- Локальная модель (пример: Ollama) ---
# OLLAMA_HOST=http://localhost:11434
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_PROVIDER=ollama

# Название коллекции в Qdrant
VECTOR_COLLECTION_NAME=project-knowledge
